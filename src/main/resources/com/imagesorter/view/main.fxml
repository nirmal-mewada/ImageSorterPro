<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.imagesorter.controller.MainController"
            focusTraversable="true">

    <!-- Menu Bar -->
    <top>
        <MenuBar>
            <Menu mnemonicParsing="false" text="File">
                <MenuItem fx:id="openFolderMenuItem" mnemonicParsing="false" text="Open Folder..." accelerator="Ctrl+O" />
                <SeparatorMenuItem />
                <MenuItem fx:id="configureFoldersMenuItem" mnemonicParsing="false" text="Configure Folders..." accelerator="Ctrl+P" />
                <SeparatorMenuItem />
                <MenuItem fx:id="exitMenuItem" mnemonicParsing="false" text="Exit" accelerator="Alt+F4" />
                <!--                <MenuItem fx:id="resetFocus" mnemonicParsing="false" text="Reset Focus"  />-->

            </Menu>
            <Menu mnemonicParsing="false" text="View">
                <MenuItem mnemonicParsing="false" text="Zoom In" accelerator="Ctrl+Plus" disable="true" />
                <MenuItem mnemonicParsing="false" text="Zoom Out" accelerator="Ctrl+Minus" disable="true" />
                <MenuItem mnemonicParsing="false" text="Actual Size" accelerator="Ctrl+0" disable="true" />
            </Menu>
            <Menu mnemonicParsing="false" text="Help">
                <MenuItem mnemonicParsing="false" text="Keyboard Shortcuts" accelerator="F1" disable="true" />
                <MenuItem mnemonicParsing="false" text="About" disable="true" />
            </Menu>
        </MenuBar>
    </top>

    <!-- Main Content Area -->
    <center>
        <SplitPane dividerPositions="0.3" HBox.hgrow="ALWAYS">
            <!-- Left Panel - Hotkey Folder List -->
            <VBox spacing="5.0" minWidth="100.0" maxWidth="600.0">
                <Label text="Destination Folders" styleClass="section-title" />
                <CheckBox text="Enable click to move" fx:id="clickToMoveCheckBox"
                          selected="true" styleClass="help-text" />
                <Separator />
                <ListView fx:id="hotkeyListView" VBox.vgrow="ALWAYS"
                          styleClass="hotkey-list1" minHeight="200.0">
                </ListView>

                <Separator />

                <Label text="Press (Shift+ to Archive) any keys  1-9 or a-z to move current image" styleClass="help-text" />
                <Label text="Press 0 to move to global Archive folder" styleClass="help-text" />
                <Label text="CTRL + SHIFT + {X} : Config update" styleClass="help-text" />
                <Label text="CTRL + Z : Undo" styleClass="help-text" />
                <Label text="Delete Key: Delete current image" styleClass="help-text" />
                <Separator />
                <Label text="Navigation:" styleClass="help-text" />
                <Label text="   ← → Arrow Keys: Previous/Next" styleClass="help-text" />
                <Label text="   Mouse Click: Left=Previous, Right=Next" styleClass="help-text" />

            </VBox>

            <!-- Center Panel - Image Viewer -->
            <VBox spacing="5.0">
                <Label text="Image Preview" styleClass="section-title" />

                <SplitPane dividerPositions="0.2" orientation="VERTICAL" VBox.vgrow="ALWAYS">
                    <items>
                        <HBox fx:id="thumbnailBox" alignment="CENTER" spacing="5" styleClass="thumbnail-bar">
                            <!-- Thumbnails will be added here dynamically -->
                        </HBox>

                        <ScrollPane fx:id="imageScrollPane" VBox.vgrow="ALWAYS"
                                    fitToWidth="true" fitToHeight="true"
                                    pannable="true" styleClass="image-scroll-pane"
                                    hbarPolicy="NEVER" vbarPolicy="NEVER">
                            <StackPane>
                                <ImageView fx:id="imageView" preserveRatio="true" smooth="true"
                                           pickOnBounds="true" styleClass="main-image" />
                            </StackPane>
                        </ScrollPane>
                    </items>
                </SplitPane>
            </VBox>
        </SplitPane>
    </center>

    <!-- Bottom Panel - Status Bar -->
    <bottom>
        <VBox spacing="5.0">
            <Separator />
            <HBox spacing="2.0" alignment="CENTER_LEFT">
                <padding>
                    <Insets left="10.0" right="10.0" top="5.0" />
                </padding>

                <Label fx:id="lastAction" text="Last Action: No Action"
                       styleClass="status-label" />
            </HBox>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <padding>
                    <Insets bottom="5.0" left="10.0" right="10.0" />
                </padding>

                <Label fx:id="currentFileLabel" text="No images loaded"
                       styleClass="status-label" HBox.hgrow="SOMETIMES" />

                <Separator orientation="VERTICAL" />

                <Label fx:id="progressLabel" text="Image 0 / 0"
                       styleClass="status-label" />

                <Separator orientation="VERTICAL" />

<!--                <Label fx:id="remainingLabel" text="Remaining: 0"-->
<!--                       styleClass="status-label" />-->
                <Region HBox.hgrow="ALWAYS" />

                <ProgressBar fx:id="progressBar" progress="0.0"
                             prefWidth="150.0" visible="false" />
                <Separator orientation="VERTICAL" />

                <Label fx:id="currentFolderLabel" text="N/A"
                       styleClass="status-label" />
                <Label fx:id="memoryUsage" text="Mem: Used: ?% /? MB"
                       styleClass="status-label" />

            </HBox>

        </VBox>
    </bottom>

</BorderPane>