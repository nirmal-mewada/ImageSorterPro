<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.imagesorter.controller.MainController"
            focusTraversable="true">

    <!-- Menu Bar -->
    <top>
        <MenuBar>
            <Menu mnemonicParsing="false" text="File">
                <MenuItem fx:id="openFolderMenuItem" mnemonicParsing="false" text="Open Folder..." accelerator="Ctrl+O" />
                <SeparatorMenuItem />
                <MenuItem fx:id="configureFoldersMenuItem" mnemonicParsing="false" text="Configure Folders..." accelerator="Ctrl+P" />
                <MenuItem fx:id="configureRulesMenuItem" mnemonicParsing="false" text="Configure Rules..." accelerator="Ctrl+Shift+P" />
                <MenuItem fx:id="applyRulesMenuItem" mnemonicParsing="false" text="Apply Rules to Folder" accelerator="Ctrl+Shift+R" />
                <SeparatorMenuItem />
                <MenuItem fx:id="exitMenuItem" mnemonicParsing="false" text="Exit" accelerator="Alt+F4" />
            </Menu>
            <Menu fx:id="bookmarksMenu" mnemonicParsing="false" text="Bookmarks">
                <MenuItem fx:id="addBookmarkMenuItem" mnemonicParsing="false" text="Add Current Folder to Bookmarks" />
                <MenuItem fx:id="removeBookmarkMenuItem" mnemonicParsing="false" text="Remove a Bookmark..." />
                <SeparatorMenuItem fx:id="bookmarksSeparator" />
                <!-- Dynamic bookmarks will be appended here -->
            </Menu>
            <Menu mnemonicParsing="false" text="View">
                <MenuItem fx:id="toggleLeftViewMenuItem" mnemonicParsing="false" text="Show/Hide Left View"/>
                <MenuItem fx:id="toggleRightViewMenuItem" mnemonicParsing="false" text="Show/Hide Metadata Panel"/>
                <MenuItem fx:id="toggleThumbnailBoxMenuItem" mnemonicParsing="false" text="Show/Hide Thumbnail Box"/>
                <SeparatorMenuItem/>
                <MenuItem fx:id="toggleFullScreenMenuItem" mnemonicParsing="false" text="Toggle Full Screen" accelerator="F11"/>
                <SeparatorMenuItem/>
                <Menu mnemonicParsing="false" text="Action Mode">
                    <RadioMenuItem fx:id="actionModeMoveMenuItem" mnemonicParsing="false" text="Move Directly" selected="true" />
                    <RadioMenuItem fx:id="actionModeCopyMenuItem" mnemonicParsing="false" text="Copy Directly" />
                    <RadioMenuItem fx:id="actionModeStagedMoveMenuItem" mnemonicParsing="false" text="Stage Move (Batch)" />
                    <RadioMenuItem fx:id="actionModeStagedCopyMenuItem" mnemonicParsing="false" text="Stage Copy (Batch)" />
                </Menu>
                <Menu mnemonicParsing="false" text="Sort By">
                    <RadioMenuItem fx:id="sortByNameMenuItem" mnemonicParsing="false" text="Name" selected="true" />
                    <RadioMenuItem fx:id="sortByCreatedMenuItem" mnemonicParsing="false" text="Date Created" />
                    <RadioMenuItem fx:id="sortByModifiedMenuItem" mnemonicParsing="false" text="Date Modified" />
                    <RadioMenuItem fx:id="sortBySizeMenuItem" mnemonicParsing="false" text="File Size" />
                    <SeparatorMenuItem />
                    <RadioMenuItem fx:id="sortOrderAscMenuItem" mnemonicParsing="false" text="Ascending" selected="true" />
                    <RadioMenuItem fx:id="sortOrderDescMenuItem" mnemonicParsing="false" text="Descending" />
                </Menu>
                <Menu mnemonicParsing="false" text="Slideshow">
                    <CheckMenuItem fx:id="slideshowPlayMenuItem" mnemonicParsing="false" text="Play Slideshow" accelerator="F5"/>
                    <Menu mnemonicParsing="false" text="Interval">
                        <RadioMenuItem fx:id="interval1sMenuItem" mnemonicParsing="false" text="1 Second" />
                        <RadioMenuItem fx:id="interval2sMenuItem" mnemonicParsing="false" text="2 Seconds" />
                        <RadioMenuItem fx:id="interval3sMenuItem" mnemonicParsing="false" text="3 Seconds" selected="true" />
                        <RadioMenuItem fx:id="interval5sMenuItem" mnemonicParsing="false" text="5 Seconds" />
                        <RadioMenuItem fx:id="interval10sMenuItem" mnemonicParsing="false" text="10 Seconds" />
                        <RadioMenuItem fx:id="intervalCustomMenuItem" mnemonicParsing="false" text="Custom..." />
                    </Menu>
                </Menu>
                <SeparatorMenuItem/>
                <MenuItem mnemonicParsing="false" text="Zoom In" accelerator="Ctrl+Plus" disable="true" />
                <MenuItem mnemonicParsing="false" text="Zoom Out" accelerator="Ctrl+Minus" disable="true" />
                <MenuItem mnemonicParsing="false" text="Actual Size" accelerator="Ctrl+0" disable="true" />
            </Menu>
            <Menu fx:id="themeMenu" mnemonicParsing="false" text="Theme">
                <RadioMenuItem fx:id="themePrimerLightMenuItem" mnemonicParsing="false" text="Primer Light" />
                <RadioMenuItem fx:id="themePrimerDarkMenuItem" mnemonicParsing="false" text="Primer Dark" />
                <RadioMenuItem fx:id="themeNordLightMenuItem" mnemonicParsing="false" text="Nord Light" />
                <RadioMenuItem fx:id="themeNordDarkMenuItem" mnemonicParsing="false" text="Nord Dark" />
                <RadioMenuItem fx:id="themeCupertinoLightMenuItem" mnemonicParsing="false" text="Cupertino Light" />
                <RadioMenuItem fx:id="themeCupertinoDarkMenuItem" mnemonicParsing="false" text="Cupertino Dark" />
                <RadioMenuItem fx:id="themeDraculaMenuItem" mnemonicParsing="false" text="Dracula" />
            </Menu>
            <Menu mnemonicParsing="false" text="Help">
                <MenuItem fx:id="helpShortcutsMenuItem" mnemonicParsing="false" text="Keyboard Shortcuts" accelerator="F1" />
                <MenuItem mnemonicParsing="false" text="About" disable="true" />
            </Menu>
        </MenuBar>
    </top>

    <!-- Main Content Area -->
    <center>
        <SplitPane fx:id="horizontalSplitPane" dividerPositions="0.25" HBox.hgrow="ALWAYS">
            <!-- Left Panel - Hotkey Folder List -->
            <VBox fx:id="leftVBox" spacing="8.0" minWidth="200.0" maxWidth="600.0" prefWidth="240.0">
                <padding>
                    <javafx.geometry.Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <CheckBox text="Enable click to move" fx:id="clickToMoveCheckBox"
                              selected="true" styleClass="help-text" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ToggleButton fx:id="pinLeftButton" styleClass="pin-button" text="📌" selected="false">
                        <tooltip>
                            <Tooltip text="Pin panel in Full Screen" />
                        </tooltip>
                    </ToggleButton>
                </HBox>
                <CheckBox text="Auto-advance on move" fx:id="autoAdvanceCheckBox"
                          selected="true" styleClass="help-text" />
                <Separator />

                <ListView fx:id="hotkeyListView" VBox.vgrow="ALWAYS"
                          styleClass="hotkey-list1" minHeight="200.0">
                </ListView>
            </VBox>

            <!-- Center Panel - Image Viewer -->
            <VBox spacing="5.0">
                <SplitPane fx:id="verticalSplitPane" dividerPositions="0.1" orientation="VERTICAL" VBox.vgrow="ALWAYS">
                    <items>
                        <HBox fx:id="thumbnailContainer" alignment="CENTER_LEFT" styleClass="thumbnail-bar" spacing="10.0">
                            <HBox fx:id="thumbnailBox" alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                                <!-- Thumbnails will be added here dynamically -->
                            </HBox>
                            <ToggleButton fx:id="pinThumbnailButton" styleClass="pin-button" text="📌" selected="false">
                                <tooltip>
                                    <Tooltip text="Pin thumbnails in Full Screen" />
                                </tooltip>
                                <HBox.margin>
                                    <javafx.geometry.Insets right="10.0" />
                                </HBox.margin>
                            </ToggleButton>
                        </HBox>

                        <ScrollPane fx:id="imageScrollPane" VBox.vgrow="ALWAYS"
                                    fitToWidth="true" fitToHeight="true"
                                    pannable="false" styleClass="image-scroll-pane"
                                    hbarPolicy="NEVER" vbarPolicy="NEVER">

                           <StackPane fx:id="mediaContainer">
                                <ImageView fx:id="imageView" preserveRatio="true" smooth="true"
                                           pickOnBounds="true" styleClass="main-image"/>

                            </StackPane>
                        </ScrollPane>
                    </items>
                </SplitPane>
            </VBox>

            <!-- Right Panel - Metadata -->
            <VBox fx:id="rightVBox" spacing="10.0" minWidth="150.0" maxWidth="400.0" prefWidth="250.0" styleClass="hotkey-list">
                <padding>
                    <javafx.geometry.Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Metadata Properties" styleClass="section-title" />
                    <Region HBox.hgrow="ALWAYS" />
                    <ToggleButton fx:id="pinRightButton" styleClass="pin-button" text="📌" selected="false">
                        <tooltip>
                            <Tooltip text="Pin panel in Full Screen" />
                        </tooltip>
                    </ToggleButton>
                </HBox>
                <Separator />
                
                <VBox spacing="10.0" style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 6; -fx-border-color: -color-border-default; -fx-border-width: 1; -fx-border-radius: 6;">
                    <padding>
                        <javafx.geometry.Insets top="10.0" right="10.0" bottom="10.0" left="10.0" />
                    </padding>
                    <Label text="Interactive Metadata" style="-fx-font-weight: bold;" />
                    
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label text="Rating:" minWidth="55.0" alignment="CENTER_RIGHT"/>
                        <HBox fx:id="starRatingBox" spacing="2.0">
                            <Button fx:id="star1" text="☆" style="-fx-padding: 2 4; -fx-background-color: transparent; -fx-font-size: 14px; -fx-text-fill: -color-warning-fg;"/>
                            <Button fx:id="star2" text="☆" style="-fx-padding: 2 4; -fx-background-color: transparent; -fx-font-size: 14px; -fx-text-fill: -color-warning-fg;"/>
                            <Button fx:id="star3" text="☆" style="-fx-padding: 2 4; -fx-background-color: transparent; -fx-font-size: 14px; -fx-text-fill: -color-warning-fg;"/>
                            <Button fx:id="star4" text="☆" style="-fx-padding: 2 4; -fx-background-color: transparent; -fx-font-size: 14px; -fx-text-fill: -color-warning-fg;"/>
                            <Button fx:id="star5" text="☆" style="-fx-padding: 2 4; -fx-background-color: transparent; -fx-font-size: 14px; -fx-text-fill: -color-warning-fg;"/>
                        </HBox>
                    </HBox>
                    
                    <HBox alignment="CENTER_LEFT" spacing="5.0">
                        <Label text="Label:" minWidth="55.0" alignment="CENTER_RIGHT"/>
                        <HBox fx:id="colorLabelBox" spacing="5.0" alignment="CENTER_LEFT">
                            <Button fx:id="colorRed" style="-fx-background-color: #ff5555; -fx-min-width: 16px; -fx-min-height: 16px; -fx-max-width: 16px; -fx-max-height: 16px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="colorYellow" style="-fx-background-color: #ffaa00; -fx-min-width: 16px; -fx-min-height: 16px; -fx-max-width: 16px; -fx-max-height: 16px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="colorGreen" style="-fx-background-color: #55ff55; -fx-min-width: 16px; -fx-min-height: 16px; -fx-max-width: 16px; -fx-max-height: 16px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="colorBlue" style="-fx-background-color: #5555ff; -fx-min-width: 16px; -fx-min-height: 16px; -fx-max-width: 16px; -fx-max-height: 16px; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            <Button fx:id="colorClear" text="✖" style="-fx-padding: 0 4; -fx-background-color: transparent; -fx-font-size: 10px; -fx-text-fill: -color-fg-muted; -fx-cursor: hand;"/>
                        </HBox>
                    </HBox>
                    
                    <GridPane hgap="5.0" vgap="6.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="55.0" prefWidth="55.0" halignment="RIGHT" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        
                        <Label text="Title:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                        <TextField fx:id="metaTitleField" promptText="Add title..." GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                        
                        <Label text="Desc:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                        <TextField fx:id="metaDescField" promptText="Add description..." GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                        
                        <Label text="Tags:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-size: 11px;"/>
                        <TextField fx:id="metaTagsField" promptText="comma-separated..." GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-font-size: 11px;"/>
                    </GridPane>
                    
                    <HBox alignment="CENTER_RIGHT" spacing="5.0">
                        <Button fx:id="saveMetaButton" text="Save Meta" styleClass="primary-button" style="-fx-font-size: 10px; -fx-padding: 3 8;"/>
                    </HBox>
                </VBox>
                
                <Separator />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="image-scroll-pane" hbarPolicy="NEVER">
                    <GridPane fx:id="metadataGridPane" hgap="10.0" vgap="8.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="90.0" prefWidth="110.0" halignment="RIGHT" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" />
                        </columnConstraints>
                    </GridPane>
                </ScrollPane>
            </VBox>
        </SplitPane>

    </center>

    <!-- Bottom Panel - Status Bar -->
    <bottom>
        <VBox spacing="5.0">
            <Separator />
            <HBox spacing="2.0" alignment="CENTER_LEFT">
                <padding>
                    <Insets left="10.0" right="10.0" top="5.0" />
                </padding>

                <Label fx:id="lastAction" text="Last Action: No Action"
                       styleClass="status-label" />
            </HBox>
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <padding>
                    <Insets bottom="5.0" left="10.0" right="10.0" />
                </padding>

                <Label fx:id="currentFileLabel" text="No images loaded"
                       styleClass="status-label" HBox.hgrow="SOMETIMES" />

                <Separator orientation="VERTICAL" />

                <Label fx:id="progressLabel" text="Image 0 / 0"
                       styleClass="status-label" />

                <Separator orientation="VERTICAL" />

                <Label fx:id="remainingLabel" text=""
                                       styleClass="status-label" />
                
                <Separator orientation="VERTICAL" />

                <!-- Staging Batch Controls in bottom status bar -->
                <HBox fx:id="batchControlsBox" spacing="5.0" alignment="CENTER_LEFT" visible="false" managed="false">
                    <Label fx:id="stagedCountLabel" text="Staged: 0" styleClass="status-label" />
                    <Button fx:id="commitBatchButton" text="Commit Staged" styleClass="primary-button" />
                    <Button fx:id="clearBatchButton" text="Clear Batch" styleClass="secondary-button" />
                    <Separator orientation="VERTICAL" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <ProgressBar fx:id="progressBar" progress="0.0"
                             prefWidth="150.0" visible="false" />
                <Separator orientation="VERTICAL" />

                <Label fx:id="currentFolderLabel" text="N/A"
                       styleClass="status-label" />
                <Label fx:id="memoryUsage" text="Mem: Used: ?% /? MB"
                       styleClass="status-label" />

            </HBox>

        </VBox>
    </bottom>

</BorderPane>